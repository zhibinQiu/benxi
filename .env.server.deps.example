# 远程依赖栈（服务器侧，供本机 remote-dev 连接）
# 用法: cp .env.server.deps.example .env
#       EXPOSE_DEPS=1 bash scripts/stack.sh up --profile knowflow --profile speech \
#         postgres redis minio pdf2zh-api speech-api \
#         knowflow-mysql knowflow-infinity knowflow-gotenberg ragflow knowflow-backend

ZHITAN_VERSION=3.9.3
DATA_ROOT=./data
COMPOSE_PROJECT_NAME=lvye
STACK_USE_MIRROR=1
EXPOSE_DEPS=1
STACK_PROFILES="knowflow speech"

POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

MYSQL_PASSWORD=infini_rag_flow
DOC_ENGINE=infinity
INFINITY_VERSION=v0.6.0-dev5

# 暴露端口（40001 保留给同机 Dify 设计系统）
REMOTE_POSTGRES_PORT=40002
REMOTE_REDIS_PORT=40003
REMOTE_MINIO_PORT=40004
REMOTE_PDF2ZH_PORT=40005
REMOTE_SPEECH_PORT=40006
REMOTE_RAGFLOW_PORT=40007
REMOTE_KNOWFLOW_BACKEND_PORT=40008
REMOTE_MYSQL_PORT=40009

# amd64 服务器预构建镜像示例：
# RAGFLOW_PLATFORM=linux/amd64
# RAGFLOW_IMAGE=zxwei/knowflow:v2.1.8
# KNOWFLOW_SERVER_IMAGE=zxwei/knowflow-server:v2.1.8
