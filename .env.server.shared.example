# 服务器全栈 + 本机 remote-dev 共用数据
# 见 docs/zh/operations/server-shared.md

ZHITAN_VERSION=4.2.1
DATA_ROOT=./data
COMPOSE_PROJECT_NAME=lvye
FRONTEND_PORT=40005
STACK_USE_MIRROR=1
STACK_PROFILES="knowflow speech"

# 全栈 + 挂载后端（server-up）；本机 dev 连 TCP 40002–40004、40006，HTTP 依赖走 :40005/deps/…
EXPOSE_DEPS=1
EXPOSE_DEPS_DB_ONLY=1
SERVER_MOUNT_CODE=1

REMOTE_POSTGRES_PORT=40002
REMOTE_REDIS_PORT=40003
REMOTE_MINIO_PORT=40004
REMOTE_MYSQL_PORT=40006
REMOTE_GATEWAY_PORT=40005

POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
REDIS_PASSWORD=infini_rag_flow

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

KNOWFLOW_ENABLED=true
DOC_ENGINE=infinity
INFINITY_VERSION=v0.6.0-dev5
MYSQL_PASSWORD=infini_rag_flow
MACOS=0
RAGFLOW_PLATFORM=linux/amd64
RAGFLOW_IMAGE=docker.1ms.run/zxwei/knowflow:v2.1.8
KNOWFLOW_SERVER_IMAGE=docker.1ms.run/zxwei/knowflow-server:v2.1.8

PDF2ZH_IMAGE=registry.cn-hangzhou.aliyuncs.com/docker-qzb/zhitan-pdf2zh:3.4.0-amd64
SPEECH_IMAGE=zhitan-speech:3.4.0-amd64

FUNASR_DEVICE=cpu
DIARIZATION_ENABLED=true
