# 统一容器栈配置（复制为仓库根目录 .env）
# 用法: cp .env.stack.example .env

ZHITAN_VERSION=4.0.5
DATA_ROOT=./data
FRONTEND_PORT=40005

# 国内镜像：Docker Hub → docker.1ms.run；PyPI/npm → 清华/npmmirror
STACK_USE_MIRROR=1
# Docker Hub 代理：默认 1ms；若 HAP429/缺层可改为 docker.m.daocloud.io
DOCKER_MIRROR=docker.1ms.run
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_REGISTRY=https://registry.npmmirror.com
APT_MIRROR=mirrors.tuna.tsinghua.edu.cn
HF_ENDPOINT=https://hf-mirror.com

# --- 阿里云 ACR（Python 运行时镜像，供服务器 pull + 挂载源码）---
# 登录: docker login registry.cn-hangzhou.aliyuncs.com
# REGISTRY_IMAGE_PREFIX=registry.cn-hangzhou.aliyuncs.com/your-namespace/
# BUILD_PLATFORMS=linux/amd64,linux/arm64
# INSTALL_PAGEINDEX=1

# 平台（复制 platform/.env 中密钥等到此，或 env_file 叠加）
# JWT_SECRET=change-me
# DEEPSEEK_API_KEY=

POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# 若 KnowFlow 报 MinIO 认证失败，可与 knowflow 对齐为 rag_flow / infini_rag_flow

KNOWFLOW_ENABLED=false

# --- profile: knowflow（Infinity 向量库）---
# 启动: bash scripts/stack.sh up --profile knowflow
DOC_ENGINE=infinity
INFINITY_VERSION=v0.6.0-dev5
MYSQL_PASSWORD=infini_rag_flow
MEM_LIMIT=8073741824
TIMEZONE=Asia/Shanghai
MACOS=1
KNOWFLOW_LIGHTEN=1
KNOWFLOW_NEED_MIRROR=1
RAGFLOW_PLATFORM=linux/arm64
KNOWFLOW_SERVER_PLATFORM=linux/arm64
# amd64 预构建（build 后 save 或 pull）:
# RAGFLOW_PLATFORM=linux/amd64
# RAGFLOW_IMAGE=zxwei/knowflow:v2.1.8
# KNOWFLOW_SERVER_IMAGE=zxwei/knowflow-server:v2.1.8

# --- profile: speech ---
FUNASR_DEVICE=cpu
DIARIZATION_ENABLED=true

# 开发覆盖 compose.dev.yaml
# VITE_DEV_API_TARGET=http://api:8000
