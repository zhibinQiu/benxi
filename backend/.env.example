# =============================================================================
# 本析 — 环境配置（唯一模板）
#   本地全栈:  cp .env.example .env
#   本地前后端 + 远程依赖:  REMOTE_HOST=<IP或域名> ./dev.sh remote-dev
#   修正:  ./dev.sh env
#   部署:  ./dev.sh deploy  （生成 .env.docker，勿覆盖本地 .env）
#   KnowFlow: cp knowflow.env.example knowflow.env
#   SSH 目标: cp deploy.target.example deploy.target
# =============================================================================
# 本地用 127.0.0.1 / 5433；deploy 会把地址改为 postgres/redis/minio 等 Docker 服务名

APP_NAME=本析
# 前台展示（留空 FRONTEND_APP_TITLE 时使用 APP_NAME；主题 system|light|dark；配色 purple|blue|custom）
FRONTEND_APP_TITLE=
FRONTEND_DEFAULT_THEME=system
FRONTEND_COLOR_SCHEME=blue
FRONTEND_PRIMARY_COLOR=
PLATFORM_VERSION=4.8.1
DEBUG=false

DATABASE_URL=postgresql+psycopg2://platform:platform@127.0.0.1:5433/platform
# 启动时数据库引导：auto（默认，schema 已对齐则跳过 DDL）| full | light | off
# DB_STARTUP_BOOTSTRAP=auto
# 连接池
# - 本地单 worker 开发：下方 20/20（约 40 瞬时并发）
# - 单机生产档位 C：由 compose.yaml / compose.server.yaml 注入 12/8（API）与 10/5（Celery），勿在 .env 改大以免 dev 误用
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
# 只读副本（留空则读写均走 DATABASE_URL）
# DATABASE_READ_URL=postgresql+psycopg2://platform:platform@127.0.0.1:5433/platform
# PostgreSQL 单条 SQL 超时（毫秒；0=不设置）
# DB_STATEMENT_TIMEOUT_MS=30000
# 慢查询日志阈值（毫秒；0=关闭）
# DB_SLOW_QUERY_LOG_MS=500
# 数据库熔断：连续失败达阈值后冷却，快速 503
# DB_CIRCUIT_ENABLED=true
# DB_CIRCUIT_FAILURE_THRESHOLD=5
# DB_CIRCUIT_COOLDOWN_SEC=20
# 单 worker 长 SSE 并发上限（LLM/Agent 流式）；超出返回「系统繁忙」
# 生产 compose 档位 C 覆盖为 12
STREAM_MAX_CONCURRENT_PER_WORKER=12
STREAM_ACQUIRE_TIMEOUT=8
# 后台任务：重任务走 Celery；进程内兜底线程池大小（登录预热等）
BACKGROUND_JOB_MAX_WORKERS=4
BACKGROUND_JOBS_USE_CELERY=true
REDIS_URL=redis://127.0.0.1:6379/0

JWT_SECRET=change-me-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false

BOOTSTRAP_ADMIN_PHONE=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=系统管理员
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_EMAIL=admin@local

# 跨域：* 允许任意来源（与 allow_credentials 互斥，后端自动关闭 Cookie 凭证）
# 生产可改为逗号分隔白名单，如 http://your-server:40005,http://localhost:40005
CORS_ORIGINS=*

# 对外 API 路径前缀（Nginx 将 /ai/api 反代到后端 /api；前端构建 VITE_API_BASE=/ai）
API_PUBLIC_PATH_PREFIX=/ai
# 浏览器请求平台后端的根地址（如 /ai 或 http://your-server:40005/ai）；留空则用 API_PUBLIC_PATH_PREFIX
# PLATFORM_API_BASE_URL=/ai

# pdf2zh 翻译服务（docker compose 内为 http://pdf2zh-api:7861）
PDF2ZH_API_URL=http://127.0.0.1:7861
# PPT 上传转 PDF（KnowFlow 栈内 Gotenberg：http://knowflow-gotenberg:3000；留空则文本提取回退）
# GOTENBERG_URL=http://knowflow-gotenberg:3000

# KnowFlow / RAGFlow（本地 Docker 栈，见 ./dev.sh knowflow；config.py 默认 false，本地栈示例启用）
KNOWFLOW_ENABLED=true
KNOWFLOW_BACKEND_URL=http://127.0.0.1:5001
RAGFLOW_API_URL=http://127.0.0.1:9380
# 推荐 mapped：平台用户 1:1 对应 RAGFlow 账号，文档按库隔离
RAGFLOW_ACCOUNT_MODE=mapped
# RAGFlow MySQL 连接超时配置（秒；默认 connect=5, read=30, write=30）
# 知识库文档量大时，task/document 表的查询可能超过 30s，需适当加大
# RAGFLOW_MYSQL_CONNECT_TIMEOUT=5
# RAGFLOW_MYSQL_READ_TIMEOUT=30
# RAGFLOW_MYSQL_WRITE_TIMEOUT=30
# 仅 RAGFLOW_ACCOUNT_MODE=shared 时填写（生产勿用 shared）
# RAGFLOW_SHARED_EMAIL=admin@gmail.com
# RAGFLOW_SHARED_PASSWORD=admin
# KnowFlow 分级知识库：mapped 用户需能创建 dataset（经 KnowFlow RBAC 授予 admin）
RAGFLOW_GRANT_GLOBAL_ADMIN=true
RAGFLOW_SYNC_ON_LOGIN=true
RAGFLOW_SYNC_ON_LOGIN_LIMIT=100
# 进入知识问答 iframe 时是否阻塞同步文档（false 加快首屏；前端会在 iframe 加载后后台 sync=true 补同步）
RAGFLOW_SYNC_ON_EMBED=false
# 全员共用 RAGFlow 模型供应商/API（从模板租户复制到每个用户，默认开启）
RAGFLOW_LLM_SHARED_FROM_TEMPLATE=true
# 可选：指定模板 RAGFlow 租户 id；留空则优先 bootstrap 系统管理员（已配模型时）或 tenant_llm 最全的账号
# RAGFLOW_LLM_TEMPLATE_TENANT_ID=
# 可选：按邮箱指定模板；留空则自动解析（不建议生产写死 admin@gmail.com）
# RAGFLOW_LLM_TEMPLATE_EMAIL=
# 可选；留空则使用当前平台用户在 RAGFlow 的登录会话同步文档
RAGFLOW_API_KEY=
RAGFLOW_DATASET_NAME=平台知识库
RAGFLOW_DATASET_PREFIX=zt-platform
RAGFLOW_DEPT_DATASET_PREFIX=zt-dept
RAGFLOW_SYNC_DOC_LIMIT=100

# 文档中心单文件上传上限（MB，默认 200）
# DOCUMENT_UPLOAD_MAX_FILE_MB=200
# 知识库默认解析与索引行为（详见 config.py）
# KNOWLEDGE_DEFAULT_PARSER_ID=naive
# KNOWLEDGE_REINDEX_DEFAULT_PARSER_ID=naive
# KNOWLEDGE_DEFAULT_LAYOUT_RECOGNIZE=DeepDOC
# KNOWLEDGE_DEFAULT_CHUNK_TOKEN_NUM=512
# KNOWLEDGE_DETAIL_LIVE_INDEX_META=false
# KNOWLEDGE_PARSE_INITIAL_WAIT_SEC=1800
# KNOWLEDGE_PARSE_MAX_WAIT_SEC=86400
# 列表/树默认读库内索引状态，勿对 RAGFlow 逐条探活（1000+ 文档必备）
KNOWLEDGE_LIST_LIVE_INDEX_META=false
# KNOWLEDGE_RAGFLOW_META_CACHE_TTL_SEC=60
# 平台 Redis/内存缓存（文档库分级、文件夹列表；Redis 不可用时降级为进程内 TTL）
# PLATFORM_CACHE_ENABLED=true
# PLATFORM_CACHE_TTL_SEC=60
# PLATFORM_CACHE_CLIENT_CONFIG_TTL_SEC=300
# PLATFORM_CACHE_DASHBOARD_TTL_SEC=30
# PLATFORM_CACHE_FEATURES_TTL_SEC=60
# PLATFORM_CACHE_DOCUMENT_DETAIL_TTL_SEC=90
# DOCUMENT_LIBRARY_CACHE_TTL_SEC=180
# KB_FOLDERS_CACHE_TTL_SEC=120
# SCOPE_TREE_CACHE_TTL_SEC=300

# 录音转文字 / 语音转写（本地 speech-api，见 ./dev.sh speech local）
SPEECH_SERVICE_URL=http://127.0.0.1:8765
# 模型缓存目录（默认 <仓库>/.run/speech-models，Docker/本地共用）
SPEECH_MODELS_DIR=
FUNASR_ASR_MODEL=paraformer-zh
# 中文标点推荐 ct-punc-c
STT_LANGUAGE=zh
STT_MAX_FILE_MB=100
DIARIZATION_ENABLED=true

# 录音总结（DeepSeek 在线 API，可与 pdf2zh 翻译共用密钥）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 对话 LLM token 控制（字符预算为 input 保守估计；可按模型上下文调大/调小）
# CHAT_PROMPT_MAX_CHARS=32000
# CHAT_REPORT_PROMPT_MAX_CHARS=48000
# CHAT_HISTORY_MAX_CHARS=6000
# CHAT_HISTORY_MAX_MESSAGES=8
# CHAT_CONTEXT_MAX_CHARS=10000
# CHAT_REPORT_CONTEXT_MAX_CHARS=16000
# CHAT_USER_MESSAGE_MAX_CHARS=4000
# CHAT_MAX_OUTPUT_TOKENS=0
# 0=普通对话也不限制输出；设为正整数可限制非报告类回复长度（报告生成始终不限）

# -----------------------------------------------------------------------------
# 模型服务（资源管理可在线改 URL + 模型名 + Key，与 .env 互为默认值）
# 目标架构：语言 / 嵌入 / 视觉 / OCR 均走项目内本地推理服务；
# 开发阶段可临时填在线 API（如硅基流动），上线后改为本地地址即可，无需改业务代码。
# -----------------------------------------------------------------------------
# 语言模型（未填 PLATFORM_LLM_* 时回退 DEEPSEEK_*）
# PLATFORM_LLM_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_LLM_API_KEY=
# PLATFORM_LLM_MODEL=deepseek-chat
# 语音合成（未填时从硅基流动等兼容端点回退，不会使用 DeepSeek LLM）
# PLATFORM_TTS_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_TTS_API_KEY=
# PLATFORM_TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
# 嵌入模型
# PLATFORM_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_EMBEDDING_API_KEY=
# PLATFORM_EMBEDDING_MODEL=BAAI/bge-m3
# PLATFORM_EMBEDDING_FACTORY=SILICONFLOW
# Rerank（可选；未填 Key/URL 时回退嵌入模型配置）
# PLATFORM_RERANK_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_RERANK_API_KEY=
# PLATFORM_RERANK_MODEL=Qwen/Qwen3-Reranker-8B
# VL 模型（PDF 图表增强 IMAGE2TEXT）
# PLATFORM_VL_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_VL_API_KEY=
# PLATFORM_VL_MODEL=Qwen/Qwen3-VL-8B-Instruct
# PaddleOCR-VL（硅基流动或本地 layout-parsing / vLLM）
# PLATFORM_PADDLEOCR_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_PADDLEOCR_API_KEY=
# PLATFORM_PADDLEOCR_MODEL=PaddlePaddle/PaddleOCR-VL-1.5
# 兼容旧字段：仅填自建 OCR 根地址（无模型名时使用）
# PLATFORM_PADDLEOCR_URL=http://127.0.0.1:8080
# 知识库 PDF 默认版面 OCR（DeepDOC / PaddleOCR / Plain Text 等；引用截图推荐 DeepDOC）
# KNOWLEDGE_DEFAULT_LAYOUT_RECOGNIZE=DeepDOC
# 知识检索召回：top_k（默认 5）、相似度阈值（默认 0.32，越高引用越少）
# KNOWLEDGE_RETRIEVAL_TOP_K=5
# KNOWLEDGE_RETRIEVAL_SIMILARITY_THRESHOLD=0.32
# KNOWLEDGE_RETRIEVAL_VECTOR_WEIGHT=0.3

# 智能问数 / 双碳问答（设计系统在上游服务器时改为对应地址；仅本地有设计系统则 127.0.0.1）
EMBED_PROXY_MODE=path
DESIGN_SYSTEM_UPSTREAM_URL=http://127.0.0.1:40001
DESIGN_SYSTEM_PROXY_PREFIX=/design-system-ui
SMART_DATA_QUERY_PATH=/ai/smart-data-query
# 智能问数 v2（对话 API，密钥仅写在本地 .env，勿提交仓库）
SMART_DATA_QUERY_V2_DIFY_BASE_URL=http://127.0.0.1:40001/v1
SMART_DATA_QUERY_V2_DIFY_API_KEY=
# 双碳问答 v2（对话 API 地址通常与问数一致，应用密钥独立）
CARBON_QA_V2_CHAT_BASE_URL=http://127.0.0.1:40001/v1
CARBON_QA_V2_CHAT_API_KEY=
CARBON_QA_PATH=/ai/retrieval
CARBON_AI_V1_PATH=/ai
CARBON_PLATFORM_URL=
SMART_FORECAST_EMBED_MODE=direct
SMART_FORECAST_UPSTREAM_URL=http://127.0.0.1:8501
SMART_FORECAST_PROXY_PREFIX=/smart-forecast-ui

# PageIndex 树形索引（自托管源码在 third_party/pageindex-upstream；入口在文档详情「结构索引」，非系统功能卡片）
PAGEINDEX_ENABLED=true
# PAGEINDEX_WORKSPACE_DIR=
# PAGEINDEX_MODEL=

# 知识图谱：文档索引完成后 LLM 自动抽取实体/关系（需配置语言模型 + 开启 feature.kg 权限）
KG_EXTRACTION_ENABLED=true
# KG_EXTRACTION_MAX_CHARS=10000

# Agentic RAG：知识检索 / 报告生成多轮规划检索（需配置语言模型）
# KNOWLEDGE_AGENTIC_ENABLED=true
# KNOWLEDGE_AGENTIC_MAX_ROUNDS=2
# KNOWLEDGE_AGENTIC_QA_MAX_SUB_QUESTIONS=4
# KNOWLEDGE_AGENTIC_REPORT_MAX_SUB_QUESTIONS=6

# AIP 智能体互联（GB/Z 185）：结构化 handoff + 对外发现/调用
# AIP_ENABLED=true
# AIP_COUNTRY=cn
# AIP_ORG_TYPE=inst
# AIP_ORG_ID=platform
# AIP_AGENT_SERIAL=001
# AIP_EXTERNAL_AGENTS_JSON=[]
# 流式调用：POST /api/v1/aip/interact/stream（SSE，需 JWT 或 sk-aip- 密钥）

# MCP Skill 互联：外部 MCP Server 接入 + 平台 Skill 对外暴露
# MCP_ENABLED=true
# MCP_SERVICE_BASE_URL=https://your-host.example.com/api/v1/mcp
# MCP_EXTERNAL_SKILLS_JSON=[]

# 浏览器 RPA（本析智能体内置 browser_* 工具；需 pip install '.[browser]' && playwright install chromium）
# AGENT_BROWSER_HEADLESS=true
# AGENT_BROWSER_SESSION_TTL_SECONDS=1800
# AGENT_BROWSER_MAX_STEPS_PER_SESSION=50
# AGENT_BROWSER_ALLOWED_DOMAINS=
# AGENT_BROWSER_SCREENSHOT_MAX_KB=800
# AGENT_BROWSER_AUTO_TASK_MAX_STEPS=15

# FireCrawl 网页全文提取（增强联网搜索：读取网页正文 Markdown 而非 snippets）
# 注册免费 Key: https://www.firecrawl.dev
# 自部署 OSS: https://github.com/nickliqian/firecrawl  (默认端口 3002)
# 服务器已部署自托管实例，内网地址: http://firecrawl-api:3002
# FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=http://firecrawl-api:3002
# 搜索后读取前几条链接的全文（默认 3；设为 0 保持旧 snippet-only 行为）
# FIRECRAWL_READ_FULL_MAX_URLS=3

# ---- 免费网页 AI Bridge（通过浏览器操控豆包/千问/DeepSeek）----
# 浏览器窗口模式（生图推荐 false 让用户看到浏览器；服务器部署必须 true）
# FREE_WEB_AI_HEADLESS=false
# 连接已有 Chrome CDP（端口）；0 或不填则自动启动独立浏览器
# FREE_WEB_AI_CDP_PORT=9222
# Chrome 可执行文件路径（CDP_PORT=0 时启动独立浏览器需此配置）
#   macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   服务器部署：留空则自动使用 Playwright 内置 Chromium
# FREE_WEB_AI_CHROME_PATH=
# 持久化用户数据目录（保存各 AI 网站登录态）
# FREE_WEB_AI_PROFILE_DIR=~/.free-web-ai-profile
# HTTP 代理（中国大陆用户推荐配置）
# FREE_WEB_AI_PROXY_SERVER=http://127.0.0.1:7897
# 默认 provider（qwen/doubao/deepseek）
# FREE_WEB_AI_DEFAULT_PROVIDER=qwen
# 超时设置（毫秒）
# FREE_WEB_AI_TIMEOUT_MS=120000
# FREE_WEB_AI_PROVIDER_TIMEOUT_MS=180000
#
# 服务器部署注意：
#   - 确保已安装 Playwright 浏览器：pip install 'playwright>=1.49.0' && playwright install chromium
#   - HEADLESS=true，CHROME_PATH 留空使用 Playwright 内置 Chromium
#   - Docker 部署需 pip install + playwright install chromium 在构建阶段完成
#   - 登录态：首次需在有头模式下启动一次，登录 AI 网站后 profile_dir 可复用

# Docker 镜像内置 Playwright Chromium（无头服务器 RPA；compose 默认 INSTALL_BROWSER=1）
# INSTALL_BROWSER=1

# Human-in-the-Loop（HITL）：AI 工具执行前需用户确认的工具列表
# 逗号分隔工具名；留空使用内置默认集（delete_document,delete_user,run_skill_script 等）
# 空 = 使用内置默认集
# HITL_CONFIRM_TOOLS=

# 以下由 deploy 写入 .env.docker，本地 .env 勿填：
# DEPLOY_HOST=
# FRONTEND_PORT=40005
# DEPLOY_ARCH=amd64

# Optional: Apprise URLs for external notifications (later)
# APPRISE_URLS=
