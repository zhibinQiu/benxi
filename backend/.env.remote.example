# =============================================================================
# 本地 remote-dev（服务器 GATEWAY_MODE=1）
# HTTP 依赖统一经 :40005/deps/…；TCP 仍直连原端口
# 生成: REMOTE_HOST=<服务器IP或域名> ./dev.sh remote-dev
# =============================================================================

REMOTE_DEPS=1
REMOTE_HOST=YOUR_REMOTE_HOST
REMOTE_GATEWAY_PORT=40005

# 系统标题（全局统一来源，也可设置 FRONTEND_APP_TITLE 覆盖；资源管理前台配置可运行期修改）
APP_NAME=本析
DEBUG=true
CORS_ORIGINS=*
API_PUBLIC_PATH_PREFIX=/ai
PLATFORM_API_BASE_URL=/ai

DATABASE_URL=postgresql+psycopg2://platform:platform@YOUR_REMOTE_HOST:40002/platform
# 远程共享库：按服务器 max_connections 调整；200 人在线生产部署建议独立 PG + 多 API 实例
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20
KNOWLEDGE_LIST_LIVE_INDEX_META=false
REDIS_URL=redis://:infini_rag_flow@YOUR_REMOTE_HOST:40003/0

MINIO_ENDPOINT=YOUR_REMOTE_HOST:40004
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false

PDF2ZH_API_URL=http://YOUR_REMOTE_HOST:40005/deps/pdf2zh
SPEECH_SERVICE_URL=http://YOUR_REMOTE_HOST:40005/deps/speech

KNOWFLOW_ENABLED=true
KNOWFLOW_BACKEND_URL=http://YOUR_REMOTE_HOST:40005/deps/knowflow
RAGFLOW_API_URL=http://YOUR_REMOTE_HOST:40005/deps/ragflow
RAGFLOW_API_KEY=

RAGFLOW_ACCOUNT_MODE=mapped
RAGFLOW_GRANT_GLOBAL_ADMIN=true
RAGFLOW_SYNC_ON_LOGIN=false
RAGFLOW_SYNC_ON_EMBED=false
RAGFLOW_LLM_SHARED_FROM_TEMPLATE=true
RAGFLOW_MYSQL_HOST=YOUR_REMOTE_HOST
RAGFLOW_MYSQL_PORT=40006
RAGFLOW_MYSQL_PASSWORD=infini_rag_flow
RAGFLOW_MYSQL_DB=rag_flow

DIARIZATION_ENABLED=true

EMBED_PROXY_MODE=path
DESIGN_SYSTEM_UPSTREAM_URL=http://YOUR_REMOTE_HOST:40001
DESIGN_SYSTEM_PROXY_PREFIX=/design-system-ui
SMART_DATA_QUERY_V2_DIFY_BASE_URL=http://YOUR_REMOTE_HOST:40001/v1
CARBON_QA_V2_CHAT_BASE_URL=http://YOUR_REMOTE_HOST:40001/v1

JWT_SECRET=change-me-in-production-use-long-random-string
DEEPSEEK_API_KEY=
BOOTSTRAP_ADMIN_PHONE=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123

# 模型服务（资源管理默认值；密钥请填本机 .env，勿提交仓库）
# PLATFORM_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_EMBEDDING_API_KEY=
# PLATFORM_EMBEDDING_MODEL=BAAI/bge-m3
# PLATFORM_EMBEDDING_FACTORY=SILICONFLOW
# Rerank（检索重排序；未填 Key/URL 时回退嵌入配置）
# PLATFORM_RERANK_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_RERANK_API_KEY=
# PLATFORM_RERANK_MODEL=Qwen/Qwen3-Reranker-8B
PLATFORM_VL_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_VL_API_KEY=
PLATFORM_VL_MODEL=Qwen/Qwen3-VL-8B-Instruct
# PaddleOCR-VL（文件内容提取与知识库版面解析；未填时回退 VL / 嵌入的硅基流动配置）
PLATFORM_PADDLEOCR_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_PADDLEOCR_API_KEY=
PLATFORM_PADDLEOCR_MODEL=PaddlePaddle/PaddleOCR-VL-1.5
