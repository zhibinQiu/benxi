# 复制为 platform/tunnel.target 并填写（勿提交含密钥的副本）
#   cp platform/tunnel.target.example platform/tunnel.target
#
# 本机 ./dev.sh local 启动后，自动建立 SSH 反向隧道；
# 他人访问 http://<TUNNEL_HOST>:<TUNNEL_REMOTE_PORT>/ai/ 即连到你本机 Vite。
#
# 服务器要求：
#   1. sshd 开启 GatewayPorts clientspecified（或 yes）
#   2. 防火墙放行 TUNNEL_REMOTE_PORT
#   3. 本机可免密 SSH 登录（ssh-copy-id）

TUNNEL_ENABLED=1
TUNNEL_USER=root
TUNNEL_HOST=YOUR_REMOTE_HOST
# 服务器监听端口（建议 40010；40000-40009 通常为依赖栈占用）
TUNNEL_REMOTE_PORT=40010
# 本机 Vite 端口（与 LOCAL_DEV_WEB_PORT 一致）
TUNNEL_LOCAL_PORT=40005
# 服务器绑定：0.0.0.0 供他人访问；127.0.0.1 仅服务器本机可测
TUNNEL_BIND=0.0.0.0
