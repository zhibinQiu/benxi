{
  "name": "doc-platform-frontend",
  "private": true,
  "version": "4.6.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:mobile": "vite build --config vite.config.mobile.js && cp dist-mobile/index.mobile.html dist-mobile/index.html",
    "preview": "vite preview",
    "lint": "eslint src --quiet",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "mobile:build": "npm run build:mobile && npx cap sync",
    "mobile:android": "npm run build:mobile && npx cap sync && npx cap open android",
    "mobile:ios": "npm run build:mobile && npx cap sync && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.7",
    "@capacitor/cli": "^7.6.7",
    "@capacitor/core": "^7.6.7",
    "@capacitor/ios": "^7.6.7",
    "@vicons/ionicons5": "^0.12.0",
    "dompurify": "^3.4.11",
    "echarts": "^6.1.0",
    "mammoth": "^1.12.0",
    "marked": "^15.0.12",
    "mermaid": "^11.15.0",
    "naive-ui": "^2.40.5",
    "pdfjs-dist": "^4.10.38",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.17.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^6.0.5",
    "vite-plugin-compression": "^0.5.1"
  }
}
