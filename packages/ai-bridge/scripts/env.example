# AI-Bridge 环境配置
# 复制到 packages/ai-bridge/.env 或项目根目录 .env

# Chrome 可执行文件路径
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/google-chrome-stable
CHROMIUM_PATH=

# CDP 调试端口
CDP_PORT=9222

# HTTP 代理（中国大陆用户推荐配置）
PROXY_SERVER=http://127.0.0.1:7897

# Chrome 用户数据目录（保存 AI 网站登录态，只需登录一次）
CHROME_PROFILE=~/.chrome-debug-profile

# 无头模式 (true/false)
HEADLESS=false

# 日志文件
LOG_FILE=/tmp/ai-bridge-chrome.log
