# Linux amd64 服务器 Docker 部署模板 — 仅用于生成 .env.docker，勿复制为本地 .env
#   bash scripts/sync_deploy_env.sh
# 或: cp .env.amd64.example .env.docker

APP_NAME=doc-platform
PLATFORM_VERSION=2.7.1
DEBUG=false

DEPLOY_HOST=172.19.134.45
FRONTEND_PORT=40005

DATABASE_URL=postgresql+psycopg2://platform:platform@postgres:5432/platform
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-me-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
