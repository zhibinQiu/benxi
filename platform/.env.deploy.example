# Docker amd64 部署模板（与本地 platform/.env 参数对齐，仅服务地址不同）
# 推荐: bash scripts/sync_deploy_env.sh  从本地 .env 同步密钥后再部署
# 或:   cp .env.deploy.example .env

APP_NAME=doc-platform
PLATFORM_VERSION=2.2.0
DEBUG=false

DEPLOY_HOST=172.19.134.45
FRONTEND_PORT=80

DATABASE_URL=postgresql+psycopg2://platform:platform@postgres:5432/platform
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-me-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_EMAIL=admin@local

CORS_ORIGINS=*

PDF2ZH_API_URL=http://pdf2zh-api:7861

# KnowFlow（与本地一致）
KNOWFLOW_ENABLED=true
KNOWFLOW_BACKEND_URL=http://knowflow-backend:5000
KNOWFLOW_UI_URL=http://172.19.134.45:9380
KNOWFLOW_UI_EMBED_MODE=iframe
RAGFLOW_API_URL=http://ragflow-server:9380
KNOWFLOW_UI_PROXY_PREFIX=/ragflow-ui
RAGFLOW_ACCOUNT_MODE=mapped
RAGFLOW_SHARED_EMAIL=admin@gmail.com
RAGFLOW_SHARED_PASSWORD=admin
RAGFLOW_GRANT_GLOBAL_ADMIN=false
RAGFLOW_SYNC_ON_LOGIN=true
RAGFLOW_SYNC_ON_LOGIN_LIMIT=30
RAGFLOW_LLM_SHARED_FROM_TEMPLATE=true
RAGFLOW_LLM_TEMPLATE_EMAIL=admin@gmail.com
RAGFLOW_API_KEY=
RAGFLOW_DATASET_NAME=智碳平台知识库
RAGFLOW_DATASET_PREFIX=zt-platform
KNOWFLOW_THEME_PRIMARY=#18a058
KNOWFLOW_THEME_PRIMARY_HOVER=#36ad6a
KNOWFLOW_THEME_PRIMARY_PRESSED=#0c7a43
KNOWFLOW_THEME_APP_NAME=智碳平台AI系统
RAGFLOW_DEPT_DATASET_PREFIX=zt-dept
RAGFLOW_SYNC_DOC_LIMIT=50

# 录音转文字（模型与本地一致）
SPEECH_SERVICE_URL=http://speech-api:8765
SPEECH_MODELS_DIR=
FUNASR_ASR_MODEL=paraformer-zh
STT_LANGUAGE=zh
STT_MAX_FILE_MB=100
DIARIZATION_ENABLED=true
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 智能问数 / 双碳问答（与本地 .env 一致）
EMBED_PROXY_MODE=path
DESIGN_SYSTEM_UPSTREAM_URL=http://172.19.134.45:40001
DESIGN_SYSTEM_PROXY_PREFIX=/design-system-ui
SMART_DATA_QUERY_PATH=/ai/smart-data-query
SMART_DATA_QUERY_V2_DIFY_BASE_URL=http://172.19.134.45:40001/v1
SMART_DATA_QUERY_V2_DIFY_API_KEY=app-61GFhU5Lw1nESxMXv7mmuSzR
CARBON_QA_V2_CHAT_BASE_URL=http://172.19.134.45:40001/v1
CARBON_QA_V2_CHAT_API_KEY=app-eTtTSHqC9w2Di8CHVUVLu98s
CARBON_QA_PATH=/ai/retrieval
