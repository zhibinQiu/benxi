# =============================================================================
# AI 办公系统 — 环境配置（唯一模板）
#   本地全栈:  cp .env.example .env
#   本地前后端 + 远程依赖:  bash scripts/setup-remote-dev-env.sh && ./dev.sh remote-dev
#              （模板见 .env.remote.example，默认服务器 172.19.134.45）
#   修正:  ./dev.sh env
#   部署:  ./dev.sh deploy  （生成 .env.docker，勿覆盖本地 .env）
#   KnowFlow: cp knowflow.env.example knowflow.env
#   SSH 目标: cp deploy.target.example deploy.target
# =============================================================================
# 本地用 127.0.0.1 / 5433；deploy 会把地址改为 postgres/redis/minio 等 Docker 服务名

APP_NAME=AI 办公系统
# 前台展示（留空 FRONTEND_APP_TITLE 时使用 APP_NAME；主题 system|light|dark）
FRONTEND_APP_TITLE=
FRONTEND_DEFAULT_THEME=system
PLATFORM_VERSION=4.0.3
DEBUG=false

# 系统说明文档目录（Docker 默认 /app/system-docs；本地留空则自动用仓库根目录）
# SYSTEM_DOCS_ROOT=

DATABASE_URL=postgresql+psycopg2://platform:platform@127.0.0.1:5433/platform
# 启动时数据库引导：auto（默认，schema 已对齐则跳过 DDL）| full | light | off
# DB_STARTUP_BOOTSTRAP=auto
# 连接池（按并发用户数调整；默认 pool=10 overflow=10；远程 REMOTE_DEPS=1 时单进程封顶约 10）
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
# 后台任务：重任务走 Celery；进程内兜底线程池大小（登录预热等）
BACKGROUND_JOB_MAX_WORKERS=4
BACKGROUND_JOBS_USE_CELERY=true
REDIS_URL=redis://127.0.0.1:6379/0

JWT_SECRET=change-me-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false

BOOTSTRAP_ADMIN_PHONE=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=系统管理员
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_EMAIL=admin@local

# 跨域：* 允许任意来源（与 allow_credentials 互斥，后端自动关闭 Cookie 凭证）
# 生产可改为逗号分隔白名单，如 http://172.19.134.45:40005,http://localhost:40005
CORS_ORIGINS=*

# 对外 API 路径前缀（Nginx 将 /ai/api 反代到后端 /api；前端构建 VITE_API_BASE=/ai）
API_PUBLIC_PATH_PREFIX=/ai
# 浏览器请求平台后端的根地址（如 /ai 或 http://172.19.134.45:40005/ai）；留空则用 API_PUBLIC_PATH_PREFIX
# PLATFORM_API_BASE_URL=/ai

# pdf2zh 翻译服务（docker compose 内为 http://pdf2zh-api:7861）
PDF2ZH_API_URL=http://127.0.0.1:7861

# KnowFlow / RAGFlow（本地 Docker 栈，见 ./dev.sh knowflow）
# 平台仅使用 RAGFlow API 与 knowflow-backend，不部署 KnowFlow Web UI
KNOWFLOW_ENABLED=true
KNOWFLOW_BACKEND_URL=http://127.0.0.1:5001
RAGFLOW_API_URL=http://127.0.0.1:9380
# 推荐 mapped：平台用户 1:1 对应 RAGFlow 账号，文档按库隔离
RAGFLOW_ACCOUNT_MODE=mapped
# 仅 RAGFLOW_ACCOUNT_MODE=shared 时填写（生产勿用 shared）
# RAGFLOW_SHARED_EMAIL=admin@gmail.com
# RAGFLOW_SHARED_PASSWORD=admin
# KnowFlow 分级知识库：mapped 用户需能创建 dataset（经 KnowFlow RBAC 授予 admin）
RAGFLOW_GRANT_GLOBAL_ADMIN=true
RAGFLOW_SYNC_ON_LOGIN=true
RAGFLOW_SYNC_ON_LOGIN_LIMIT=100
# 进入知识问答 iframe 时是否阻塞同步文档（false 加快首屏；前端会在 iframe 加载后后台 sync=true 补同步）
RAGFLOW_SYNC_ON_EMBED=false
# 全员共用 RAGFlow 模型供应商/API（从模板租户复制到每个用户，默认开启）
RAGFLOW_LLM_SHARED_FROM_TEMPLATE=true
# 可选：指定模板 RAGFlow 租户 id；留空则优先 bootstrap 系统管理员（已配模型时）或 tenant_llm 最全的账号
# RAGFLOW_LLM_TEMPLATE_TENANT_ID=
# 可选：按邮箱指定模板；留空则自动解析（不建议生产写死 admin@gmail.com）
# RAGFLOW_LLM_TEMPLATE_EMAIL=
# 可选；留空则使用当前平台用户在 RAGFlow 的登录会话同步文档
RAGFLOW_API_KEY=
RAGFLOW_DATASET_NAME=平台知识库
RAGFLOW_DATASET_PREFIX=zt-platform
RAGFLOW_DEPT_DATASET_PREFIX=zt-dept
RAGFLOW_SYNC_DOC_LIMIT=100

# 文档中心性能：列表默认不实时拉 RAGFlow 解析进度（详情页仍实时）
# KNOWLEDGE_LIST_LIVE_INDEX_META=false
# KNOWLEDGE_RAGFLOW_META_CACHE_TTL_SEC=60
# 平台 Redis/内存缓存（文档库分级、文件夹列表；Redis 不可用时降级为进程内 TTL）
# PLATFORM_CACHE_ENABLED=true
# PLATFORM_CACHE_TTL_SEC=60
# DOCUMENT_LIBRARY_CACHE_TTL_SEC=120
# KB_FOLDERS_CACHE_TTL_SEC=45

# 录音转文字 / 会议助手（本地 speech-api，见 scripts/start_speech_local.sh）
SPEECH_SERVICE_URL=http://127.0.0.1:8765
# 模型缓存目录（默认 <仓库>/.run/speech-models，Docker/本地共用）
SPEECH_MODELS_DIR=
FUNASR_ASR_MODEL=paraformer-zh
# 中文标点推荐 ct-punc-c
STT_LANGUAGE=zh
STT_MAX_FILE_MB=100
DIARIZATION_ENABLED=true

# 录音总结（DeepSeek 在线 API，可与 pdf2zh 翻译共用密钥）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# 模型服务（资源管理可在线改 URL + 模型名 + Key，与 .env 互为默认值）
# 目标架构：语言 / 嵌入 / 视觉 / OCR 均走项目内本地推理服务；
# 开发阶段可临时填在线 API（如硅基流动），上线后改为本地地址即可，无需改业务代码。
# -----------------------------------------------------------------------------
# 语言模型（未填 PLATFORM_LLM_* 时回退 DEEPSEEK_*）
# PLATFORM_LLM_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_LLM_API_KEY=
# PLATFORM_LLM_MODEL=deepseek-chat
# 嵌入模型
# PLATFORM_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_EMBEDDING_API_KEY=
# PLATFORM_EMBEDDING_MODEL=BAAI/bge-m3
# PLATFORM_EMBEDDING_FACTORY=SILICONFLOW
# Rerank（可选）
# PLATFORM_RERANK_BASE_URL=
# PLATFORM_RERANK_API_KEY=
# PLATFORM_RERANK_MODEL=
# VL 模型（PDF 图表增强 IMAGE2TEXT）
# PLATFORM_VL_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_VL_API_KEY=
# PLATFORM_VL_MODEL=Qwen/Qwen3-VL-8B-Instruct
# PaddleOCR-VL（硅基流动或本地 layout-parsing / vLLM）
# PLATFORM_PADDLEOCR_BASE_URL=https://api.siliconflow.cn/v1
# PLATFORM_PADDLEOCR_API_KEY=
# PLATFORM_PADDLEOCR_MODEL=PaddlePaddle/PaddleOCR-VL-1.5
# 兼容旧字段：仅填自建 OCR 根地址（无模型名时使用）
# PLATFORM_PADDLEOCR_URL=http://127.0.0.1:8080
# 知识库 PDF 默认版面 OCR（DeepDOC / PaddleOCR / Plain Text 等；引用截图推荐 DeepDOC）
# KNOWLEDGE_DEFAULT_LAYOUT_RECOGNIZE=DeepDOC
# 知识检索召回：top_k（默认 5）、相似度阈值（默认 0.32，越高引用越少）
# KNOWLEDGE_RETRIEVAL_TOP_K=5
# KNOWLEDGE_RETRIEVAL_SIMILARITY_THRESHOLD=0.32
# KNOWLEDGE_RETRIEVAL_VECTOR_WEIGHT=0.3

# 智能问数 / 双碳问答（设计系统在上游服务器时保留远程 IP；仅本地有设计系统则改为 127.0.0.1）
EMBED_PROXY_MODE=path
DESIGN_SYSTEM_UPSTREAM_URL=http://172.19.134.45:40001
DESIGN_SYSTEM_PROXY_PREFIX=/design-system-ui
SMART_DATA_QUERY_PATH=/ai/smart-data-query
# 智能问数 v2（对话 API，密钥仅写在本地 .env，勿提交仓库）
SMART_DATA_QUERY_V2_DIFY_BASE_URL=http://172.19.134.45:40001/v1
SMART_DATA_QUERY_V2_DIFY_API_KEY=
# 双碳问答 v2（对话 API 地址通常与问数一致，应用密钥独立）
CARBON_QA_V2_CHAT_BASE_URL=http://172.19.134.45:40001/v1
CARBON_QA_V2_CHAT_API_KEY=
CARBON_QA_PATH=/ai/retrieval
CARBON_AI_V1_PATH=/ai
CARBON_PLATFORM_URL=http://carbon3.hy.05351757.xyz/login?redirect=/index
SMART_FORECAST_EMBED_MODE=direct
SMART_FORECAST_UPSTREAM_URL=http://127.0.0.1:8501
SMART_FORECAST_PROXY_PREFIX=/smart-forecast-ui

# 碳资产行情（CEA 默认抓取上海环交所 www.cneeex.com，需本机/服务器能访问该站）
CARBON_MARKET_LIVE_ENABLED=true
CARBON_MARKET_CNEEEX_BASE_URL=https://www.cneeex.com
CARBON_MARKET_CACHE_TTL_SECONDS=900
# 可选：自建 JSON 行情地址（见 app/services/carbon_market_live_service.py 注释）
# CARBON_MARKET_QUOTES_JSON_URL=
# CCER 日行情（全国温室气体自愿减排交易系统）
CARBON_MARKET_CCER_BASE_URL=https://www.ccer.com.cn
# 正文正则解析失败时是否调用大模型提取（需 DEEPSEEK_API_KEY）
# CARBON_MARKET_CCER_USE_LLM_PARSE=false
# 无 CCER 官方价时按 CEA 收盘价比例估算参考价（0=不估算）
CARBON_MARKET_CCER_CEA_RATIO=0.8
CARBON_MARKET_HISTORY_MAX_FETCH=30

# PageIndex 实验性树形索引（自托管源码在 third_party/pageindex-upstream）
# 索引 JSON 默认目录：platform/.run/pageindex/（可用 PAGEINDEX_WORKSPACE_DIR 指向独立磁盘/挂载卷）
PAGEINDEX_ENABLED=true
# PAGEINDEX_WORKSPACE_DIR=
# PAGEINDEX_MODEL=
# OPENAI_API_KEY=   # PageIndex 建索引时调用 LLM（可与平台语言模型共用 Key）

# CEA 历史日行情定时同步（上海时区，收盘后）
CARBON_MARKET_HISTORY_SYNC_HOUR=18
CARBON_MARKET_HISTORY_SYNC_MINUTE=0

# 以下由 deploy 写入 .env.docker，本地 .env 勿填：
# DEPLOY_HOST=
# FRONTEND_PORT=40005
# DEPLOY_ARCH=amd64

# Optional: Apprise URLs for external notifications (later)
# APPRISE_URLS=
