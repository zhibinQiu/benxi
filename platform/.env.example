# Copy to .env and adjust

APP_NAME=doc-platform
DEBUG=false

DATABASE_URL=postgresql+psycopg2://platform:platform@127.0.0.1:5432/platform
REDIS_URL=redis://127.0.0.1:6379/0

JWT_SECRET=change-me-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_EMAIL=admin@local

CORS_ORIGINS=*

# pdf2zh 翻译服务（docker compose 内为 http://pdf2zh-api:7861）
PDF2ZH_API_URL=http://127.0.0.1:7861

# Optional: Apprise URLs for external notifications (later)
# APPRISE_URLS=
