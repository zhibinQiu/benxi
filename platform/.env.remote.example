# =============================================================================
# 本地开发：前后端在本机，依赖服务在远程服务器（通过 URL 连接）
# 用法:
#   REMOTE_HOST=172.19.134.45 bash scripts/setup-remote-dev-env.sh
#   bash scripts/zhitan.sh remote-dev
#
# 服务器侧需先暴露依赖端口（见 compose.expose-deps.yaml）:
#   EXPOSE_DEPS=1 bash scripts/stack.sh up --profile knowflow --profile speech
# =============================================================================

REMOTE_DEPS=1
REMOTE_HOST=172.19.134.45

APP_NAME=AI原型演示系统
DEBUG=true
CORS_ORIGINS=*
API_PUBLIC_PATH_PREFIX=/ai
# 浏览器请求平台 API 根路径（本地 remote-dev 前端 vite :40005）
PLATFORM_API_BASE_URL=/ai

# --- 平台依赖（远程）---
DATABASE_URL=postgresql+psycopg2://platform:platform@172.19.134.45:40002/platform
REDIS_URL=redis://:infini_rag_flow@172.19.134.45:40003/0

MINIO_ENDPOINT=172.19.134.45:40004
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false

PDF2ZH_API_URL=http://172.19.134.45:40005

# --- 模型 / OCR（远程或在线；写入「资源配置」）---
# PLATFORM_LLM_BASE_URL=https://api.deepseek.com/v1
# PLATFORM_LLM_MODEL=deepseek-chat
# PLATFORM_PADDLEOCR_URL=http://172.20.32.127:7071/ocr

# --- KnowFlow / RAGFlow（远程）---
KNOWFLOW_ENABLED=true
KNOWFLOW_BACKEND_URL=http://172.19.134.45:40008
RAGFLOW_API_URL=http://172.19.134.45:40007
RAGFLOW_API_KEY=
# embed-proxy 上游：服务器 ragflow nginx
KNOWFLOW_UI_UPSTREAM_URL=http://172.19.134.45:40007
# 浏览器 iframe：走本机 vite 同源 /ragflow-ui
KNOWFLOW_UI_PUBLIC_URL=http://127.0.0.1:40005/ragflow-ui
KNOWFLOW_UI_PROXY_PREFIX=/ragflow-ui
KNOWFLOW_UI_URL=http://172.19.134.45:40007
KNOWFLOW_UI_EMBED_MODE=iframe

RAGFLOW_ACCOUNT_MODE=mapped
RAGFLOW_GRANT_GLOBAL_ADMIN=true
RAGFLOW_SYNC_ON_LOGIN=false
RAGFLOW_SYNC_ON_EMBED=false
RAGFLOW_LLM_SHARED_FROM_TEMPLATE=true
RAGFLOW_MYSQL_HOST=172.19.134.45
RAGFLOW_MYSQL_PORT=40009
RAGFLOW_MYSQL_PASSWORD=infini_rag_flow
RAGFLOW_MYSQL_DB=rag_flow

# --- 语音（远程，可选）---
SPEECH_SERVICE_URL=http://172.19.134.45:40006
DIARIZATION_ENABLED=true

# --- 设计系统（已在远程 40001）---
EMBED_PROXY_MODE=path
DESIGN_SYSTEM_UPSTREAM_URL=http://172.19.134.45:40001
DESIGN_SYSTEM_PROXY_PREFIX=/design-system-ui
SMART_DATA_QUERY_V2_DIFY_BASE_URL=http://172.19.134.45:40001/v1
CARBON_QA_V2_CHAT_BASE_URL=http://172.19.134.45:40001/v1

# 密钥请从本机 platform/.env 复制，勿提交仓库
JWT_SECRET=change-me-in-production-use-long-random-string
DEEPSEEK_API_KEY=
BOOTSTRAP_ADMIN_PHONE=15963564658
BOOTSTRAP_ADMIN_PASSWORD=admin123
