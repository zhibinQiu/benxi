# amd64 预构建镜像（参数与本地 knowflow.env 一致，仅镜像名与 MACOS 不同）
# 推荐: bash scripts/sync_deploy_env.sh
# 与平台 Docker 栈同网（deploy_amd64 COMPOSE_PROJECT_NAME=zhitanai → zhitanai_default）
KNOWFLOW_DOCKER_NETWORK=zhitanai_default

COMPOSE_PROFILES=elasticsearch
TIMEZONE=Asia/Shanghai
MACOS=0

STACK_VERSION=8.11.3
DOC_ENGINE=elasticsearch
ES_HOST=es01
ES_PORT=9200
ELASTIC_PASSWORD=infini_rag_flow
MEM_LIMIT=8073741824

MYSQL_PASSWORD=infini_rag_flow
MYSQL_HOST=mysql
MYSQL_PORT=5455
MYSQL_DBNAME=rag_flow

MINIO_HOST=minio
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9003
MINIO_USER=rag_flow
MINIO_PASSWORD=infini_rag_flow

REDIS_HOST=redis
REDIS_PORT=6380
REDIS_PASSWORD=infini_rag_flow

SVR_HTTP_PORT=9380
HF_ENDPOINT=https://hf-mirror.com

KNOWFLOW_LIGHTEN=1
KNOWFLOW_NEED_MIRROR=1

RAGFLOW_IMAGE=zxwei/knowflow:v2.1.8
KNOWFLOW_SERVER_IMAGE=zxwei/knowflow-server:v2.1.8
KNOWFLOW_BACKEND_PORT=5001

KNOWFLOW_API_URL=http://knowflow-backend:5000
RAGFLOW_BASE_URL=http://ragflow-server:9380

MANAGEMENT_ADMIN_USERNAME=admin
MANAGEMENT_ADMIN_PASSWORD=12345678
MANAGEMENT_JWT_SECRET=12345678
