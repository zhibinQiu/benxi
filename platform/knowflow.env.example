# KnowFlow 栈配置（复制为 knowflow.env）
# 与平台 Docker 栈同网（local 模式 compose 项目名 platform → platform_default）
KNOWFLOW_DOCKER_NETWORK=platform_default
COMPOSE_PROFILES=infinity
TIMEZONE=Asia/Shanghai
MACOS=1

INFINITY_VERSION=v0.6.0-dev5
DOC_ENGINE=infinity
INFINITY_HOST=infinity
MEM_LIMIT=8073741824

MYSQL_PASSWORD=infini_rag_flow
MYSQL_HOST=mysql
MYSQL_PORT=5455
MYSQL_DBNAME=rag_flow

MINIO_HOST=minio
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9003
MINIO_USER=rag_flow
MINIO_PASSWORD=infini_rag_flow

REDIS_HOST=redis
REDIS_PORT=6380
REDIS_PASSWORD=infini_rag_flow

SVR_HTTP_PORT=9380
HF_ENDPOINT=https://hf-mirror.com

# 源码构建（docker-compose.knowflow.yml 默认从源码构建 arm64 镜像）
KNOWFLOW_LIGHTEN=1
KNOWFLOW_NEED_MIRROR=1
KNOWFLOW_PLATFORM=linux/arm64

RAGFLOW_IMAGE=knowflow-ragflow:source
KNOWFLOW_SERVER_IMAGE=knowflow-server:source
KNOWFLOW_BACKEND_PORT=5001

KNOWFLOW_API_URL=http://knowflow-backend:5000
RAGFLOW_BASE_URL=http://ragflow-server:9380

MANAGEMENT_ADMIN_USERNAME=admin
MANAGEMENT_ADMIN_PASSWORD=12345678
MANAGEMENT_JWT_SECRET=12345678

# --- amd64 服务器（bash scripts/zhitan.sh deploy 会自动切换，无需单独文件）---
# MACOS=0
# KNOWFLOW_DOCKER_NETWORK=zhitanai_default
# RAGFLOW_IMAGE=zxwei/knowflow:v2.1.8
# KNOWFLOW_SERVER_IMAGE=zxwei/knowflow-server:v2.1.8
